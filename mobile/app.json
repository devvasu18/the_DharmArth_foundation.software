{
  "expo": {
    "name": "DharmArth Foundation",
    "slug": "dharmarth-mobile",
    "scheme": "dharmarth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00bfa5"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to automatically fill your delivery address for donations."
      },
      "associatedDomains": [
        "applinks:the-dharm-arth-foundation-software.vercel.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LOGO.jpg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dharmarth.foundation",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "the-dharm-arth-foundation-software.vercel.app",
              "pathPrefix": "/v"
            },
            {
              "scheme": "https",
              "host": "the-dharm-arth-foundation-software.vercel.app",
              "pathPrefix": "/donate"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow $(PRODUCT_NAME) to use your location even in the background.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ]
  }
}
