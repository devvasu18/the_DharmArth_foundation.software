{
  "expo": {
    "name": "DharmArth Foundation",
    "slug": "dharmarth-mobile",
    "scheme": "dharmarth",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/LOGO.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thedharmarth.foundation",
      "buildNumber": "8",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "We use your location to accurately fill in your address for donation receipts, billing details, and local community registration.",
        "NSPhotoLibraryUsageDescription": "We use your photo library to allow you to upload and set a profile picture.",
        "NSCameraUsageDescription": "We use your camera to allow you to take and upload a profile picture."
      },
      "associatedDomains": [
        "applinks:thedharmarth.com"
      ]
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.thedharmarth.foundation",
      "versionCode": 7,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "thedharmarth.com",
              "pathPrefix": "/v"
            },
            {
              "scheme": "https",
              "host": "thedharmarth.com",
              "pathPrefix": "/donate"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "production",
          "sounds": [
            "./assets/ring.wav"
          ],
          "smallIcons": [
            "./assets/notification-icon.png"
          ],
          "largeIcons": [
            "./assets/icon.png"
          ],
          "smallIconAccentColor": "#00bfa5"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.thedharmarth.foundation.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.thedharmarth.foundation.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "949a6026-871b-4216-8c60-4c92b457ea23"
      }
    },
    "owner": "vasudev18s-team"
  }
}